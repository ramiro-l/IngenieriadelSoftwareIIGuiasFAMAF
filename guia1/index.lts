/* ========================================================================== */

/* TODO: Cual esta bien? */

/* ---- OPCIÓN 1 ------------------------------------------------------------ */
range R = 0..1

BISTABLE = BISTABLE[0],
BISTABLE[v:R] = (trigger -> BISTABLE[1-v]).

/* . . Alternativamente . . . . . . . . . . . . . . . . . . . . . . . . . . . */
range R = 0..1

BISTABLE = BISTABLE[0],
BISTABLE[0] = (trigger -> BISTABLE[1]),
BISTABLE[1] = (trigger -> BISTABLE[0]).


BISTABLE = BISTABLE0,
BISTABLE0 = (trigger -> out.1 -> BISTABLE1),
BISTABLE1 = (trigger -> out.0 -> BISTABLE0).

/* ---- OPCIÓN 2 ------------------------------------------------------------ */
BISTABLE = FLIP,
FLIP = (trigger -> zero -> FLOP),
FLOP = (trigger -> one  -> FLIP).

/* ========================================================================== */
/*  Ejercicio 6                                                               */
/* ========================================================================== */

const MIN = 2
const MAX = 8
range R = 0..9

SENSOR = SENSOR[5],

SENSOR[n:R] = (
      when (n != 0)               to[n-1] -> SENSOR[n-1]
    | when (n != 9)               to[n+1] -> SENSOR[n+1]
    | when (n < MIN)              bajo    -> SENSOR[n]
    | when (n >= MIN && n <= MAX) normal  -> SENSOR[n]
    | when (n > MAX)              alto    -> SENSOR[n]
).

/* . . Alternativa  . . . . . . . . . . . . . . . . . . . . . . . . . . . . . */
/*     En esta opción, permitimos que el sensor pueda ir a cualquier valor,   */
/*     es decir que no hace falta incrementar de uno en uno.                  */

const MIN = 2
const MAX = 8
range R = 0..9

SENSOR = SENSOR[5],

SENSOR[n:R] = (
                                to[i:R] -> SENSOR[i]
    | when (n <= MIN)           bajo    -> SENSOR[n]
    | when (n > MIN && n < MAX) normal  -> SENSOR[n]
    | when (n >= MAX)           alto    -> SENSOR[n]
).

/* ========================================================================== */
/*  Ejercicio 7                                                               */
/* ========================================================================== */

MAQUINA = INICIO,

INICIO = (c5 -> FALTAN10 | c10 -> FALTAN5 | c20 -> DEVOLVER5),

FALTAN10 = (c5 -> FALTAN5 | c10 -> DAR_PRODUCTO | c20 -> DEVOLVER10),
FALTAN5 = (c5 -> DAR_PRODUCTO | c10 -> DEVOLVER5 | c20 -> DEVOLVER15),

DEVOLVER5 = (devolver5 -> DAR_PRODUCTO),
DEVOLVER10 = (devolver10 -> DAR_PRODUCTO),
DEVOLVER15 = (devolver15 -> DAR_PRODUCTO),

DAR_PRODUCTO = (darProducto -> MAQUINA).

/* . . Alternativa  . . . . . . . . . . . . . . . . . . . . . . . . . . . . . */

const PRECIO_PRODUCTO = 15
range RANGO_DINERO = 0..100

MAQUINA = MAQUINA[0],

MAQUINA[d:RANGO_DINERO] = (
      when (d == PRECIO_PRODUCTO) entregar_producto -> MAQUINA
        
    | when (d > PRECIO_PRODUCTO) 
                    dar_vuelto[d - PRECIO_PRODUCTO] -> MAQUINA[PRECIO_PRODUCTO]
        
    | when (d < PRECIO_PRODUCTO) c[5]  -> MAQUINA[d + 5]
    | when (d < PRECIO_PRODUCTO) c[10] -> MAQUINA[d + 10]
    | when (d < PRECIO_PRODUCTO) c[20] -> MAQUINA[d + 20]
).

/* ========================================================================== */
/*  Ejercicio 8                                                               */
/* ========================================================================== */

const MIN_FREQ = 88
const MAX_FREQ = 108

RADIO = OFF,

OFF = (on -> READY),

READY = (scan -> ON[MAX_FREQ]),

ON[f:MIN_FREQ..MAX_FREQ] = (
      off     -> OFF
    | reset   -> READY
    | found   -> READY
    | when (f > MIN_FREQ) to[f-1] -> ON[f-1]
).

/* ========================================================================== */
/*  Ejercicio 9                                                               */
/* ========================================================================== */

P = (a -> b -> P).
Q = (c -> b -> Q).
||S1 = (P || Q).
S2 = (a -> c -> b -> S2 | c -> a -> b -> S2).4

/* . . . . . . . . . . . . . . . . . . . . . . . . . . . . . . . . . . . . . . .
TODO: ¿Esto es suficiente?
RESPUESTA: 

En `||S1 = P || Q` las acciones a y c pueden intercalarse.
Luego deben sincronizarse para ejecutar la acción b.

Entonces las únicas formas de intercalar a y c son:
a -> c
c -> a

Y luego sincronizarse con b, por lo tanto las únicas trazas posibles son:
a -> c -> b
c -> a -> b

Esto corresponde exactamente a

S2 = (a -> c -> b -> S2 | c -> a -> b -> S2)

Por lo tanto S1 y S2 tienen el mismo comportamiento.
. . . . . . . . . . . . . . . . . . . . . . . . . . . . . . . . . . . . . . . */

/* ========================================================================== */
/*  Ejercicio 10                                                              */
/* ========================================================================== */
/* TODO: REVISAR */

DIRECTOR = (
    openMuseum  -> closeMuseum -> DIRECTOR
).
CONTROL = (
    openMuseum  -> enableEast -> enableWest -> CONTROL
  | closeMuseum -> disableEast -> CONTROL
).
EAST = (enableEast -> EAST | disableEast -> EAST).
WEST = (enableWest -> WEST).
||MUSEUM = (DIRECTOR || CONTROL || EAST || WEST).

/* . . Alternativa  . . . . . . . . . . . . . . . . . . . . . . . . . . . . . */

set Dors = {{east,west}.enable , {east,west}.disable}

DIRECTOR = (openMuseum  -> closeMuseum -> DIRECTOR).
CONTROL = (
    openMuseum  -> east.enable -> west.enable -> CONTROL
  | closeMuseum -> east.disable -> CONTROL
) + Dors.
DOOR = (enable -> DOOR | disable -> DOOR).

||MUSEUM = (DIRECTOR || CONTROL || east:DOOR || west:DOOR).

