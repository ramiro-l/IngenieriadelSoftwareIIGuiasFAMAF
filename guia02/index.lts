/* ========================================================================== */
/*  Ejercicio 2                                                               */
/* ========================================================================== */

/* . . Alternativa 1  . . . . . . . . . . . . . . . . . . . . . . . . . . . . */
const N_PROCESOS = 2
const N_LECTORES = 2
const N_ESCRITORES = 2

const MAX_VALOR_VAR = 2
range VALORES_VAR = 0..MAX_VALOR_VAR
set VarAlpha = { valor.{ leer[VALORES_VAR], escribir[VALORES_VAR] } }

VAR = VAR[0],
VAR[v:VALORES_VAR] = (
      leer[v] -> VAR[v]
    | escribir[nv:VALORES_VAR] -> VAR[nv] ).

LECTOR = ( 
    pedirLeer ->
    valor.leer[VALORES_VAR] ->
    terminarLeer -> LECTOR ) + VarAlpha.
ESCRITOR = ( 
    pedirEscribir ->
    valor.leer[VALORES_VAR] ->
    valor.escribir[VALORES_VAR] -> 
    terminarEscribir -> ESCRITOR ) + VarAlpha.

CONTROLADOR = CONTROLADOR[0][0][0],
CONTROLADOR[p:0..N_PROCESOS][l:0..N_LECTORES][e:0..N_ESCRITORES] = (
      when (p < N_PROCESOS && l < N_LECTORES && e == 0) 
        lector[1..N_LECTORES].pedirLeer -> CONTROLADOR[p+1][l+1][e]
    | when (p < N_PROCESOS && e < N_ESCRITORES && l == 0 && e == 0) 
        escritor[1..N_ESCRITORES].pedirEscribir -> CONTROLADOR[p+1][l][e+1]
    | when (p > 0 && l > 0) 
        lector[1..N_LECTORES].terminarLeer -> CONTROLADOR[p-1][l-1][e]
    | when (p > 0 && e > 0) 
        escritor[1..N_ESCRITORES].terminarEscribir -> CONTROLADOR[p-1][l][e-1]
).

||SYSTEM = ( 
    CONTROLADOR ||
    lector[1..N_LECTORES]:LECTOR ||
    escritor[1..N_ESCRITORES]:ESCRITOR ||
    {lector[1..N_LECTORES],escritor[1..N_ESCRITORES]}::valor:VAR
).

/* . . Alternativa 2 (con semáforo)  . . . . . . . . . . . . . . . . . . . .  */

const N_PROCESS = 2
const N_READERS = 2
const N_WRITERS = 2

range VAR_VALUES = 0..2

VAR = VAR[0],
VAR[v:VAR_VALUES] = (
      read[v] -> VAR[v]
    | write[new_value:VAR_VALUES] -> VAR[new_value] ).

SEMAPHORE (N=N_PROCESS) = SEMAPHORE[N],
SEMAPHORE[v:0..N] = (
      up -> SEMAPHORE[v+1]
    | when(v > 0)  down    -> SEMAPHORE[v-1]
    | when(v == N) acquire -> release -> SEMAPHORE[N] ),
SEMAPHORE[N+1] = ERROR. // Esto sucede si alguien hace up sin antes hacer down.

READER = ( down -> read[VAR_VALUES] -> up -> READER ).
WRITER = ( 
      down -> read[VAR_VALUES] -> up -> WRITER
    | acquire -> write[VAR_VALUES] -> release -> WRITER 
).

||SYSTEM = ( 
    reader[1..N_READERS]:READER || writer[1..N_WRITERS]:WRITER ||
    {reader[1..N_READERS], writer[1..N_WRITERS]}::VAR || 
    {reader[1..N_READERS], writer[1..N_WRITERS]}::SEMAPHORE
).

/* ========================================================================== */
/*  Ejercicio 3                                                               */
/* ========================================================================== */

const N_ASIENTOS = 3
const N_CENTRALES = 2

const Libre = 1
const Ocupado = 0
range ESTADO_ASIENTO = Ocupado..Libre
range ASIENTOS = 1..N_ASIENTOS
range CENTRALES = 1..N_CENTRALES

ASIENTO = ASIENTO[0],
ASIENTO[v:ESTADO_ASIENTO] = (
      when ( v == Libre ) reservar -> ASIENTO[1]
    | when ( v == Ocupado ) ocupado -> ASIENTO[v] 
).
LOCK = ( adquirirLock -> liberarLock -> LOCK).
||LOCK_ASIENTO = (LOCK || ASIENTO).

CENTRAL = (
    consultar[a:ASIENTOS] -> asiento[a].adquirirLock -> CONSULTAR[a]
),
CONSULTAR[a:ASIENTOS] = (
      asiento[a].reservar -> asiento[a].liberarLock -> CENTRAL
    | asiento[a].ocupado -> asiento[a].liberarLock -> CENTRAL
).

||SISTEMA = (
    { central[CENTRALES] }:CENTRAL || 
    { central[CENTRALES] }::{ asiento[ASIENTOS] }:LOCK_ASIENTO
).

/* ========================================================================== */
/*  Ejercicio 4                                                               */
/* ========================================================================== */

const N_PORCIONES = 2
const N_SALVAJES = 4
range SALVAJES = 1..N_SALVAJES

SALVAJE = ( servirse -> comer -> SALVAJE ).

COCINERO = ( agregarComida -> COCINERO ).

OLLA = OLLA[N_PORCIONES],
OLLA[n:0..N_PORCIONES] = (
          when (n > 0)  salvaje[SALVAJES].servirse -> OLLA[n-1]
        | when (n == 0) cocinero.agregarComida     -> OLLA[N_PORCIONES]
).

||TRIBU = ( salvaje[SALVAJES]:SALVAJE || cocinero::COCINERO || OLLA ).

/* ========================================================================== */
/*  Ejercicio 5                                                               */
/* ========================================================================== */

const TAM_BUFFER = 3
set Mensajes = { a, b, c, d }

PRODUCTOR =  ( producir[Mensajes] -> PRODUCTOR  ).
CONSUMIDOR = ( consumir[Mensajes] -> CONSUMIDOR ).

ONE_BUFF = (put[x:Mensajes] -> get[x] -> ONE_BUFF).
||BUFFER(N=TAM_BUFFER) = ( [1..N]:ONE_BUFF ) / {
    [i:2..N].put/[i-1].get, // Sincronización entre BUFFERS.
    producir/[1].put,
    consumir/[N].get
} @ { producir, consumir }.

||SISTEMA = ( PRODUCTOR || CONSUMIDOR || BUFFER ).

