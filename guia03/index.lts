/* ========================================================================== */
/*  Ejercicio 2                                                               */
/* ========================================================================== */

/* . . Código del Libro  . . . . . . . . . . . . . . . . . . . . . . . . . .  */

PHIL = (sitdown->right.get->left.get
          ->eat->left.put->right.put
          ->arise->PHIL).

FORK = (get -> put -> FORK).

||DINERS(N=5)= 
   forall [i:0..N-1] 
   (phil[i]:PHIL 
   ||{phil[i].left,phil[((i-1)+N)%N].right}::FORK).

/* . . Código con BUTLER  . . . . . . . . . . . . . . . . . . . . . . . . . . */

PHIL = (sitdown ->
            right.get -> left.get ->
                eat ->
            left.put -> right.put ->
        arise -> PHIL).

FORK = (get -> put -> FORK).

||DINERS(N = 5) = forall [i:0..N-1] 
   ( phil[i]:PHIL || { phil[i].left, phil[((i - 1) + N) % N].right }::FORK ).

BUTLER(N = 4) = BUTLER[N],
BUTLER[i:0..N] = (
    when (i > 0) sitdown -> BUTLER[i-1]
  | when (i < N) arise -> BUTLER[i+1]
).

||SYSTEM = (DINERS(5) || phil[0..4]::BUTLER).

/* . . Código del LIBRO . . . . . . . . . . . . . . . . . . . . . . . . . . . */

PHIL(I=0)
    = ( when (I%2 == 0) sitdown -> 
                        left.get -> right.get ->
                        eat ->
                        left.put -> right.put -> 
                        arise -> PHIL
      | when (I%2 == 1) sitdown ->
                        right.get -> left.get ->
                        eat ->
                        left.put -> right.put ->
                        arise -> PHIL
).

FORK = (get -> put -> FORK).

||DINERS(N = 5) = forall [i:0..N-1] 
   ( phil[i]:PHIL(i) || { phil[i].left, phil[((i - 1) + N) % N].right }::FORK ).
/*
La idea es que los filósofos parses (0, 2, 4) tomen primero el tenedor izquierdo 
y luego el derecho, mientras que los filósofos impares (1, 3) tomen primero el 
tenedor derecho y luego el izquierdo.

De esta manera se evita la posibilidad de que todos los filósofos tomen un 
tenedor y esperen por el otro, lo que causaría un deadlock.
*/
/* ========================================================================== */
/*  Ejercicio 11                                                              */
/* ========================================================================== */

A = ( a -> ( b -> A | a ->A ) | b -> a -> A ).

property PS = ( a -> ( b -> A | a ->A ) | b -> a -> A ).

