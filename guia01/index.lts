/* TODO: REVISAR */

CINTA = ( llegada_A -> parar_cinta -> quitar_A -> CINTA 
        | llegada_B -> parar_cinta -> quitar_B -> CINTA ).

BRAZO_ENTRADA = ( quitar_A -> poner_en_prensa -> BRAZO_ENTRADA 
                | quitar_B -> poner_en_taladro -> BRAZO_ENTRADA ).

PRENSA  = (poner_en_prensa  -> prensar  -> extraer_prensa -> PRENSA).
TALADRO = (poner_en_taladro -> taladrar -> extraer_taladro -> TALADRO).

BRAZO_SALIDA = ( extraer_prensa  -> salida_sistema -> BRAZO_SALIDA 
                | extraer_taladro -> salida_sistema -> BRAZO_SALIDA ).

||CELULA = (CINTA || BRAZO_ENTRADA || PRENSA || TALADRO || BRAZO_SALIDA).

/* ========================================================================== */
/*  Ejercicio 13                                                              */
/* ========================================================================== */
set OBJ = { a, b, c, d }

CINTA = ( 
    llegada[n:OBJ] -> 
        parar_cinta -> 
    brazoEntrada.extraer.cinta[n] -> CINTA ).

BRAZO_ENTRADA = ( 
      brazoEntrada.extraer.cinta.a ->  
      brazoEntrada.poner.prensa.a  -> BRAZO_ENTRADA 
    | brazoEntrada.extraer.cinta.b -> 
      brazoEntrada.poner.taladro.b -> BRAZO_ENTRADA
    | brazoEntrada.extraer.cinta.c -> 
      brazoEntrada.poner.prensa.c  -> BRAZO_ENTRADA
    | brazoEntrada.extraer.cinta.d -> 
      brazoEntrada.poner.taladro.d -> BRAZO_ENTRADA
).

PRENSA  = ( 
    brazoEntrada.poner.prensa.a -> 
        prensar ->
    brazoSalida.extraer.prensa.a -> PRENSA
  | brazoEntrada.poner.prensa.c -> 
        prensar ->
    brazoInterno.extraer.prensa.c -> PRENSA
  | brazoInterno.poner.prensa.d -> 
        prensar ->
    brazoSalida.extraer.prensa.d -> PRENSA
).

TALADRO = ( 
    brazoEntrada.poner.taladro.b -> 
        taladrar ->
    brazoSalida.extraer.taladro.b -> TALADRO
  | brazoInterno.poner.taladro.c -> 
        taladrar ->
    brazoSalida.extraer.taladro.c -> TALADRO
  | brazoEntrada.poner.taladro.d -> 
        taladrar ->
    brazoInterno.extraer.taladro.d -> TALADRO
).
    
BRAZO_INTERNO = ( 
      brazoInterno.extraer.prensa.c -> 
      brazoInterno.poner.taladro.c -> BRAZO_INTERNO 
    | brazoInterno.extraer.taladro.d -> 
      brazoInterno.poner.prensa.d -> BRAZO_INTERNO
).

BRAZO_SALIDA = ( 
    brazoSalida.extraer.{ prensa.a, taladro.b, taladro.c, prensa.d } ->
    salida_sistema -> BRAZO_SALIDA
).

||CELULA = (
    CINTA || 
    PRENSA || TALADRO || 
    BRAZO_ENTRADA || BRAZO_INTERNO || BRAZO_SALIDA ).

// . . . . . . . . . . . . . INTENTO DE GENERALIZACIÓN . . . . . . . . . . . . .
//  ------------------------------> NO FUNCIONA <-------------------------------

set OBJ = { a, b, c, d }
set MAQUINAS = { prensa, taladro }
set BRAZOS = { brazoEntrada, brazoInterno, brazoSalida }
set ACCIONES = { extraer, poner }

CINTA = ( 
    llegada[n:OBJ] -> 
        parar_cinta -> 
    brazoEntrada.extraer.cinta[n] -> CINTA ).

BRAZO_ENTRADA = ( 
    brazoEntrada.extraer.cinta[n:OBJ] ->  
    brazoEntrada.poner[MAQUINAS][n] -> BRAZO_ENTRADA ).

PRENSA  = ( [BRAZOS].poner.prensa[n:OBJ] -> 
                prensar ->
            [BRAZOS].extraer.prensa[n] -> PRENSA ).
TALADRO = ( [BRAZOS].poner.taladro[n:OBJ] -> 
                taladrar ->
            [BRAZOS].extraer.taladro[n] -> TALADRO ).

BRAZO_INTERNO = ( 
    brazoInterno.extraer[MAQUINAS][n:OBJ] -> 
    brazoInterno.poner[MAQUINAS][n] -> BRAZO_INTERNO ).

BRAZO_SALIDA = ( 
    brazoSalida.extraer[MAQUINAS][n:OBJ] ->
    salida_sistema -> BRAZO_SALIDA ).

CONTROLADOR = (
    brazoEntrada.extraer.cinta.a ->
        brazoEntrada.poner.prensa.a -> 
        brazoSalida.extraer.prensa.a -> 
    salida_sistema -> CONTROLADOR
  | brazoEntrada.extraer.cinta.b -> 
        brazoEntrada.poner.taladro.b -> 
        brazoSalida.extraer.taladro.b ->
    salida_sistema -> CONTROLADOR
  | brazoEntrada.extraer.cinta.c -> 
        brazoEntrada.poner.prensa.c -> 
            brazoInterno.extraer.prensa.c -> 
            brazoInterno.poner.taladro.c -> 
        brazoSalida.extraer.taladro.c ->
    salida_sistema -> CONTROLADOR
  | brazoEntrada.extraer.cinta.d -> 
        brazoEntrada.poner.taladro.d ->
            brazoInterno.extraer.taladro.d -> 
            brazoInterno.poner.prensa.d -> 
        brazoSalida.extraer.prensa.d ->
    salida_sistema -> CONTROLADOR
) + { [BRAZOS][ACCIONES][MAQUINAS][OBJ] }.

||CELULA = (
    CINTA || 
    PRENSA || TALADRO || 
    BRAZO_ENTRADA || BRAZO_INTERNO || BRAZO_SALIDA || 
    CONTROLADOR ).
