CINTA = (llegada_A -> parar_cinta -> quitar_A -> CINTA).

BRAZO_ENTRADA = (quitar_A -> poner_en_prensa -> BRAZO_ENTRADA).

PRENSA = (poner_en_prensa -> prensar -> listo_para_extraer -> PRENSA).

BRAZO_SALIDA = (listo_para_extraer -> sacar_de_prensa -> salida_sistema -> BRAZO_SALIDA).

